# ===== General =====
TZ=America/Bogota

# ===== MQTT / Maqiatto (external) =====
MQTT_BROKER_HOST=maqiatto.com
MQTT_BROKER_PORT=1883
MQTT_USER=your_maqiatto_username
MQTT_PASSWORD=replace_with_maqiatto_password
MQTT_NODERED_USER=your_maqiatto_username
MQTT_NODERED_PASSWORD=replace_with_maqiatto_password
MQTT_TOPIC_BASE=<your_maqiatto_username>/fiot/garage

# ===== MySQL / MariaDB =====
MYSQL_ROOT_PASSWORD=replace_with_strong_password
MYSQL_DATABASE=fiot_garage
MYSQL_USER=fiot_app
MYSQL_PASSWORD=replace_with_strong_password
MYSQL_HOST=mariadb
MYSQL_PORT=3306

# ===== Node identifiers =====
HARDWARE_DEVICE_ID=ESP32-GARAGE-CO-001
SIM_DEVICE_ID=SIM-GARAGE-CO-001

# ===== Command branch =====
MQTT_COMMAND_TOPIC=<your_maqiatto_username>/fiot/garage/commands
COMMANDS_ENABLED=true

# ===== Node-RED flow auto import =====
NR_AUTO_IMPORT=true
NR_FORCE_IMPORT=false

# ===== Node-RED DB startup wait =====
DB_WAIT_ENABLED=true
DB_WAIT_TIMEOUT_SEC=30
DB_WAIT_INTERVAL_SEC=1
